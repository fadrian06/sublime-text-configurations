                "vibrant-ink",
                "warm-neon",
                "wez",
                "wild-cherry",
                "wombat",
                "wryan",
                "zenburn"
              ],
              "default": "adaptive",
              "markdownDescription": "The theme name. Can be 'adaptive', 'classic', 'user', or any theme from the Terminus themes directory (e.g., 'argonaut', 'dracula', 'nord')."
            },
            "user_theme_colors": {
              "type": "object",
              "properties": {
                "background": {
                  "type": "string",
                  "markdownDescription": "Background color."
                },
                "foreground": {
                  "type": "string",
                  "markdownDescription": "Foreground text color."
                },
                "caret": {
                  "type": "string",
                  "markdownDescription": "Caret cursor color."
                },
                "block_caret": {
                  "type": "string",
                  "markdownDescription": "Block cursor color."
                },
                "selection": {
                  "type": "string",
                  "markdownDescription": "Selection background color."
                },
                "selection_foreground": {
                  "type": "string",
                  "markdownDescription": "Selection foreground color."
                },
                "black": {
                  "type": "string",
                  "markdownDescription": "ANSI black color."
                },
                "red": {
                  "type": "string",
                  "markdownDescription": "ANSI red color."
                },
                "green": {
                  "type": "string",
                  "markdownDescription": "ANSI green color."
                },
                "brown": {
                  "type": "string",
                  "markdownDescription": "ANSI brown/yellow color."
                },
                "blue": {
                  "type": "string",
                  "markdownDescription": "ANSI blue color."
                },
                "magenta": {
                  "type": "string",
                  "markdownDescription": "ANSI magenta color."
                },
                "cyan": {
                  "type": "string",
                  "markdownDescription": "ANSI cyan color."
                },
                "white": {
                  "type": "string",
                  "markdownDescription": "ANSI white color."
                },
                "light_black": {
                  "type": "string",
                  "markdownDescription": "ANSI bright black color."
                },
                "light_red": {
                  "type": "string",
                  "markdownDescription": "ANSI bright red color."
                },
                "light_green": {
                  "type": "string",
                  "markdownDescription": "ANSI bright green color."
                },
                "light_brown": {
                  "type": "string",
                  "markdownDescription": "ANSI bright brown/yellow color."
                },
                "light_blue": {
                  "type": "string",
                  "markdownDescription": "ANSI bright blue color."
                },
                "light_magenta": {
                  "type": "string",
                  "markdownDescription": "ANSI bright magenta color."
                },
                "light_cyan": {
                  "type": "string",
                  "markdownDescription": "ANSI bright cyan color."
                },
                "light_white": {
                  "type": "string",
                  "markdownDescription": "ANSI bright white color."
                }
              },
              "additionalProperties": false,
              "default": {},
              "markdownDescription": "Custom theme colors when 'theme' is set to 'user'."
            },
            "view_settings": {
              "type": "object",
              "additionalProperties": true,
              "default": {},
              "markdownDescription": "Extra view settings passed to the terminus_view (font_face, font_size, paddings, etc.)."
            },
            "reactivate_terminals": {
              "type": "boolean",
              "default": true,
              "markdownDescription": "Reactivate terminals when the window starts."
            },
            "debug": {
              "type": "boolean",
              "default": false,
              "markdownDescription": "Enable debug mode for troubleshooting."
            }
          },
          "additionalProperties": false
        }
      }
    ]
  }
}
